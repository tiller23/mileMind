{
  "blocks": {
    "posterior_chain": {
      "title": "Posterior Chain",
      "rationale_fallback": "Runners are quad-dominant by default. Training the glutes, hamstrings, and lower back balances that out and protects your stride over long mileage."
    },
    "single_leg_stability": {
      "title": "Single-Leg Stability",
      "rationale_fallback": "Running is a single-leg sport. Stability work on one leg at a time translates directly to a more efficient stride and fewer compensations."
    },
    "hip_glute": {
      "title": "Hip & Glute Activation",
      "rationale_fallback": "Weak or lazy glute medius is the source of a lot of running pain (IT band, knee, hip). These are low-load activations you can do any day."
    },
    "core_anti_rotation": {
      "title": "Core & Anti-Rotation",
      "rationale_fallback": "A stable trunk keeps your energy going forward instead of leaking sideways. Anti-rotation beats crunches for runners."
    },
    "calf_achilles": {
      "title": "Calf & Achilles Resilience",
      "rationale_fallback": "Your calves and Achilles take the biggest single load in running. Progressive eccentric work builds tendons that can handle the mileage."
    }
  },
